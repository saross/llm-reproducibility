# Source papers (not all open access, large files)
input/sources/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
*.egg-info/
.pytest_cache/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak

# Migration backups
outputs.backup-pre-migration/

# Published paper PDFs (may include non-open-access papers)
# Source papers are also covered by input/sources/ above
studies/open-science-compliance/corpus/pdfs/
corpus/pdfs/

# Extracted article full text and third-party supplements (publisher copyright;
# regenerate locally from source PDFs — see CLAUDE.md, PDF Handling).
# Convention: paper text lives at {output_dir}/{paper-slug}.txt
outputs/*/full_text.txt
outputs/*/*-et-al-*.txt
outputs/*/*-20??.txt
studies/*/outputs/*/full_text.txt
studies/*/outputs/*/*-et-al-*.txt
studies/*/outputs/*/*-20??.txt
**/reproduction/attempt-*/supplement.pdf

# Claude Code session archives tracked via Git LFS
# Use cc-session CLI to manage (pip install cc-session-toolkit)
# JSONL files tracked with: git lfs track "*.jsonl"
archive/cc-sessions/

# Corpus store convenience symlink (content lives out-of-tree; see corpus/README.md)
corpus/store

# D-2 spike log (transient)
.claude/hooks/spike-log.jsonl
